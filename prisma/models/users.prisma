model User { 
 id String @id @default(ulid())
 name String @db.VarChar(250)
 email  String @unique
 password String
 activeStatus ActiveStatus @default(ACTIVE)
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 profile Profile?
 role Role @default(USER)

posts Post[]
comments Comment[]
 @@map("users")
}



